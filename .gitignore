# ─── Input / sensitive documents ──────────────────────────────────────────────
# source document is not committed (may contain real PII)
input/*
!input/.gitkeep

# ─── Generated outputs ────────────────────────────────────────────────────────
# redacted DOCX and audit CSV stay local
out/submission/
out/rendered/
!out/reports/
generate_submission.py
deep_analysis.py
compare_docs.py


# docs folder - allowed for HLD/LLD

# Common binary / generated files
*.docx
*.pdf
*.png
*.jpg
*.jpeg
*.zip

# Assigement folder
Assigement/

# ─── Python / runtime ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
